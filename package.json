{
  "name": "souhait-me",
  "type": "module",
  "scripts": {
    "postinstall": "tsx scripts/download_assets.ts",
    "dev": "vite",
    "build": "vite build --mode client && vite build",
    "preview": "wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "lint": "concurrently --pad-prefix node:lint:*",
    "lint:typescript": "tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint .",
    "format": "eslint --fix . && stylelint --fix ."
  },
  "private": true,
  "dependencies": {
    "hono": "4.12.30",
    "honox": "0.1.55",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260702.1",
    "@hono/vite-build": "1.11.1",
    "@hono/vite-dev-server": "0.26.0",
    "@stylistic/stylelint-config": "5.0.0",
    "@tailwindcss/vite": "4.3.3",
    "@taiyme/eslint-config": "1.0.1",
    "@taiyme/vite-plugin-jsx-prune-classname": "0.0.3",
    "@types/node": "24.13.3",
    "@typescript-eslint/parser": "8.64.0",
    "concurrently": "10.0.3",
    "eslint": "9.39.5",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-plugin-better-tailwindcss": "4.6.1",
    "globals": "17.7.0",
    "jiti": "2.7.0",
    "kiso.css": "1.2.4",
    "sharp": "0.35.2",
    "stylelint": "17.14.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-recommended": "18.0.0",
    "stylelint-config-tailwindcss": "1.0.1",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "type-fest": "5.8.0",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "wrangler": "4.111.0"
  },
  "packageManager": "pnpm@10.34.3"
}